{
  "name": "coolab-core-service",
  "version": "0.1.0",
  "engines": {
    "node": "24.11.0"
  },
  "scripts": {
    "check": "pnpm run lint && pnpm run ts",
    "commit": "git add . && oco",
    "db:clear": "bash scripts/clear-local-db.sh",
    "db:create": "bash scripts/create-local-db.sh",
    "db:migrate:down": "node --env-file=.env --require tsx/cjs scripts/migrate.ts down",
    "db:migrate:up": "node --env-file=.env --require tsx/cjs scripts/migrate.ts up",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "reinstall:frozen": "rm -rf node_modules && pnpm install --frozen-lockfile",
    "reinstall": "rm -rf node_modules pnpm-lock.yaml && pnpm install",
    "start:ts:local": "node --watch --env-file=.env --require tsx/cjs src/main.ts",
    "start:ts": "node --require tsx/cjs src/main.ts",
    "test:coverage": "vitest run --coverage",
    "test": "vitest run",
    "ts": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "2.0.0",
    "@hono/swagger-ui": "0.6.1",
    "@hono/zod-openapi": "1.3.0",
    "hono": "4.12.14",
    "kysely": "0.28.16",
    "pg": "8.20.0",
    "redis": "5.12.1",
    "serialize-error": "13.0.1",
    "winston": "3.19.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.5",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/node": "24.3.1",
    "@types/pg": "8.20.0",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.2.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-import-newlines": "2.0.0",
    "eslint-plugin-package-json": "0.91.1",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-sort-keys-fix": "1.1.2",
    "globals": "17.5.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
